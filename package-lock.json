{
  "name": "application-template",
  "version": "1.0.0",
  "private": true,
  "description": "",
  "workspaces": [
    "core"
  ],
  "scripts": {
    "build": "npm run build -w core && npm run build -w backend && npm run build -w adsb-gateway && npm run build -w ui",
    "build:core": "npm run build -w core",
    "docs:generate": "npm run generate -w docs",
    "docs:serve": "npm run serve -w docs",
    "clean": "npm run clean --workspaces --if-present",
    "format": "npm run format --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "install:all": "npm install"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "devDependencies": {},
